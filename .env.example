# UNI backend configuration, template.
# Copy to `.env` and fill in the secrets:  cp .env.example .env
#
# Loaded by Env::Load(".env") at startup; values here OVERRIDE any matching
# variable already present in the real environment (setenv overwrite=1).
# Lines starting with '#' are ignored. Inline comments are NOT supported,
# everything after '=' is taken as the value (surrounding double quotes are
# stripped).
#
# Every variable below is read somewhere in the C++ code. JWT_SECRET is REQUIRED
# (no code default, the server refuses to start without it). All others show
# their built-in default; change a line to override it.

# --- Secrets ---
# REQUIRED: HMAC key for signing/verifying JWTs. Generate e.g. with:
#   openssl rand -hex 32
JWT_SECRET=

# Extra pepper mixed into password hashing. Optional (code default: empty), but
# strongly recommended in production. Changing it invalidates existing hashes.
PASSWORD_PEPPER=

# REQUIRED: 32-byte AES-256 key (base64) for encrypting DM chat history at
# rest. Generate e.g. with:
#   openssl rand -base64 32
# Changing it makes existing stored DMs undecryptable.
CHAT_DM_KEY=

# --- Server ---
PORT=9999
FRONTEND_PATH=public
DB_PATH=uni.sqlite
# Pre-load every file under FRONTEND_PATH into memory at startup (fast, but a
# file changed on disk afterwards is never picked up without a restart). Set
# to 0 in dev (alongside `cd frontend && npm run watch`, and CMake's public/
# symlink) to serve straight off disk and see rebuilds without restarting.
STATIC_CACHE=1

# --- TLS (used only when built with UNI_ENABLE_SSL=ON) ---
SSL_CERT_PATH=cert.pem
SSL_KEY_PATH=key.pem

# --- Proxy ---
# Honour X-Forwarded-For for client IP resolution (rate-limit / throttle keys).
# Set to 1 only when running behind a trusted reverse proxy.
TRUST_PROXY=0

# --- HTTP rate limiting (per IP, token bucket) ---
RATE_HTTP_BURST=120
RATE_HTTP_RPS=50
# Stricter bucket for /auth/* routes (brute-force / PBKDF2 CPU surface).
RATE_AUTH_BURST=10
RATE_AUTH_RPS=0.5

# --- Failed-login lockout (per email+IP) ---
LOGIN_MAX_FAILS=5
LOGIN_LOCKOUT_SEC=300

# --- WebSocket action rate limiting (per connection) ---
RATE_WS_BURST=30
RATE_WS_RPS=15

# --- Chat flood limiting (per username, on top of RATE_WS_*) ---
RATE_CHAT_BURST=5
RATE_CHAT_RPS=1

# --- Global chat history on join ---
# Whether a newly connected socket is pushed a shard of recent global chat
# history (set to 0 to disable entirely).
CHAT_GLOBAL_HISTORY_ON_JOIN=1
# Size of that first shard. -1 sends the entire in-memory ring buffer (up to
# 200 messages) as one shard instead of paginating it. Further history is
# fetched a shard at a time via chat_history_request (server-clamped to 100
# messages per request regardless of what's asked for).
CHAT_GLOBAL_HISTORY_SIZE=64

# --- Chat history shards ---
# Size of a paginated history shard (chat_history_request with no `limit`),
# for global, lobby, and DM chat alike. Server-clamped to 100 regardless of
# what a client requests.
CHAT_HISTORY_SHARD_SIZE=50

# --- WebSocket transport limits ---
MAX_CONN_PER_IP=10
WS_MAX_PAYLOAD=16384
WS_MAX_BACKPRESSURE=1048576
WS_IDLE_TIMEOUT=120

# --- Gameplay ---
# For Instantaneous Bots: the mandatory minimum milliseconds for a turn.
BOT_TURN_DELAY_MS=100
# Randomised "thinking" delay (ms) for bots in the wait-until-turn-end mode.
# A bot waits a random duration in [BOT_WAIT_MIN_MS, BOT_WAIT_MAX_MS).
BOT_WAIT_MIN_MS=500
BOT_WAIT_MAX_MS=3500
# Safety cap on consecutive bot moves in a single instantaneous burst.
MAX_INSTANT_BOT_STEPS=20
# Grace period (ms) a disconnected player has to reconnect before eviction.
RECONNECT_GRACE_MS=30000
# Default lobby settings applied when a new lobby is created (host can change
# them afterwards; both are clamped to the contract's bounds).
DEFAULT_TURN_TIME_MS=15000
DEFAULT_STARTING_CARDS=7
